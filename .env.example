# 複製此檔案為 .env.local，填入您的 Notion 資訊
# cp .env.example .env.local

# Notion Integration Token（取自 https://www.notion.com/my-integrations）
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 資料庫 ID（從資料庫網址取得，見下方說明）
# 網址格式：https://www.notion.so/yourworkspace/[DATABASE_ID]?v=xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
